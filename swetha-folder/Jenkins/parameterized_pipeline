pipeline {
    agent any

    parameters {
        choice(
            name: 'ENV',
            choices: ['dev','qa','prod']
        )
    }

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/Swetha98867/Amazon.git',
                    branch: 'master'
            }
        }

        stage('Deploy') {
            steps {
                echo "Deploying to ${params.ENV}"
            }
        }
    }
}
