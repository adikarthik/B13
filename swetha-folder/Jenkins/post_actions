pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                git url: 'https://github.com/Swetha98867/Amazon.git',
                    branch: 'master'
            }
        }

        stage('Compile') {
            steps {
                sh 'cd Amazon && mvn clean compile'
            }
        }

        stage('Test') {
            steps {
                sh 'cd Amazon && mvn test'
            }
        }

        stage('Package') {
            steps {
                sh 'cd Amazon && mvn package'
            }
        }

        stage('Archive') {
            steps {
                archiveArtifacts artifacts: '**/target/*.jar'
            }
        }

        stage('Deploy') {
            steps{
            sh 'sudo cp Amazon/Amazon-Web/target/*.war /opt/tomcat9/webapps/'
           }
        }
    }

    post {

        success {
            echo 'Build Successful'
        }

        failure {
            echo 'Build Failed'
        }

        always {
            cleanWs()
        }
    }
}
