pipeline{
    agent any
    stages{
        stage('checkout'){
            steps{
                git url: 'https://github.com/Swetha98867/Amazon.git' , branch:'master'
            }
        }
    stage('build'){
        steps{
            dir('Amazon'){
                sh 'mvn compile'
            }
        }
    }
    stage('test'){
        steps{
            dir('Amazon'){
                sh 'mvn test'
            }
        }
    }
    stage('package'){
        steps{
            dir('Amazon'){
                sh 'mvn package'
            }
        }
    }
    stage('Archiveartifact'){
        steps{
            archiveArtifacts artifacts: '**/target/*.war'
        }
    }
    stage('deploy to tomcat'){
        steps{
            sh 'cp Amazon/Amazon-Web/target/*.war /opt/tomcat9/webapps/'
        }
    }
    }
post{
    success{
        echo "build success"
    }
    failure{
        echo "build failure"
    }
    unstable{
        echo "build unstable"
    }
    always{
        echo "cleaning workspace"
        cleanWs()
    }
}
}
