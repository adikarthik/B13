FROM ubuntu:latest

MAINTAINER Harshitha PV

LABEL PROJECT="Amazon"
LABEL VERSION="0.0"

RUN apt-get update && \
    apt-get install -y openjdk-11-jdk wget tar

RUN wget https://archive.apache.org/dist/tomcat/tomcat-9/v9.0.120/bin/apache-tomcat-9.0.120.tar.gz

RUN tar -xzf apache-tomcat-9.0.120.tar.gz -C /opt

RUN mv /opt/apache-tomcat-9.0.120 /opt/tomcat

WORKDIR /opt/tomcat

COPY Amazon.war webapps/

EXPOSE 8080

ENTRYPOINT ["sh","bin/catalina.sh","run"]
