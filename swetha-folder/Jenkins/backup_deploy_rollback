pipeline {
    agent any

    stages {

        stage('Backup') {

            steps {

                sh '''
                mkdir -p /tmp/backup

                if [ -f /opt/tomcat9/webapps/Amazon.war ]
                then
                    cp /opt/tomcat9/webapps/Amazon.war \
                    /tmp/backup/latest.war
                fi
                '''
            }
        }

        stage('Deploy') {

            steps {

                sh '''
                cp Amazon/Amazon-Web/target/Amazon.war \
                /opt/tomcat9/webapps/
                '''
            }
        }
    }

    post {

        failure {

            sh '''
            cp /tmp/backup/latest.war \
            /opt/tomcat9/webapps/Amazon.war
            '''

            echo "Rollback Successful"
        }
    }
}
